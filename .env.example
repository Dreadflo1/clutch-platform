# ── Game API Keys (add to Vercel Environment Variables) ──

# Riot Games — https://developer.riotgames.com
# Free: 100 req/2min (dev key), 30k/10s (production)
RIOT_API_KEY=

# Steam / Dota 2 — https://steamcommunity.com/dev/apikey
# Free: ~100k req/day
STEAM_API_KEY=

# Supercell — https://developer.clashroyale.com + https://developer.brawlstars.com
# Free: 10k req/day. NOTE: IP whitelist required — use Vercel's static IP
CLASH_ROYALE_API_KEY=
BRAWL_STARS_API_KEY=

# ── Vercel KV (for challenge board persistence) ──
# Created automatically when you add KV from Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=
